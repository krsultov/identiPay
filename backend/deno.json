{
  "tasks": {
    "dev": "deno run --env-file --allow-net --allow-env --allow-read --watch src/main.ts",
    "start": "deno run --env-file --allow-net --allow-env --allow-read src/main.ts",
    "test": "deno test --env-file --allow-net --allow-env --allow-read tests/",
    "db:generate": "deno run --node-modules-dir --env-file --allow-net --allow-env --allow-read --allow-write --allow-run npm:drizzle-kit generate",
    "db:migrate": "deno run --env-file --allow-net --allow-env --allow-read src/db/migrate.ts"
  },
  "imports": {
    "hono": "npm:hono@^4.7.0",
    "hono/cors": "npm:hono@^4.7.0/cors",
    "hono/ws": "npm:hono@^4.7.0/ws",
    "drizzle-orm": "npm:drizzle-orm@^0.38.0",
    "drizzle-orm/pg-core": "npm:drizzle-orm@^0.38.0/pg-core",
    "drizzle-orm/postgres-js": "npm:drizzle-orm@^0.38.0/postgres-js",
    "drizzle-orm/postgres-js/migrator": "npm:drizzle-orm@^0.38.0/postgres-js/migrator",
    "postgres": "npm:postgres@^3.4.0",
    "drizzle-kit": "npm:drizzle-kit@^0.30.0",
    "@mysten/sui/client": "npm:@mysten/sui@^1.0.0/client",
    "@mysten/sui/transactions": "npm:@mysten/sui@^1.0.0/transactions",
    "@mysten/sui/keypairs/ed25519": "npm:@mysten/sui@^1.0.0/keypairs/ed25519",
    "@mysten/sui/utils": "npm:@mysten/sui@^1.0.0/utils",
    "@noble/curves/ed25519": "npm:@noble/curves@^1.8.0/ed25519",
    "@noble/hashes/sha256": "npm:@noble/hashes@^1.7.0/sha256",
    "@noble/hashes/sha3": "npm:@noble/hashes@^1.7.0/sha3",
    "@noble/hashes/blake2b": "npm:@noble/hashes@^1.7.0/blake2b",
    "@noble/hashes/utils": "npm:@noble/hashes@^1.7.0/utils",
    "jsonld": "npm:jsonld@^8.3.0",
    "zod": "npm:zod@^3.24.0",
    "qrcode": "npm:qrcode@^1.5.0",
    "@std/assert": "jsr:@std/assert@^1.0.0"
  },
  "compilerOptions": {
    "strict": true,
    "noImplicitAny": true
  }
}
